{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "vitest/globals", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": "./src",
    "paths": {
      "@/app": ["app"],
      "@/app/*": ["app/*"],
      "@/features/characterBuilder/*": ["features/characterBuilder/*"],
      "@/features/message": ["features/message/index.ts"],
      "@/features/message/*": ["features/message/*"],
      "@/features/levelUp": ["features/levelUp/index.ts"],
      "@/features/levelUp/*": ["features/levelUp/*"],
      "@/features/auth/*": ["features/auth/*"],
      "@/features/account/*": ["features/account/*"],
      "@/features/combat": ["features/combat/index.ts"],
      "@/features/combat/components": ["features/combat/components/index.ts"],
      "@/features/combat/*": ["features/combat/*"],
      "@/features/encounter": ["features/encounter/index.ts"],
      "@/features/encounter/components": ["features/encounter/components/index.ts"],
      "@/features/encounter/*": ["features/encounter/*"],
      "@/features/game-session": ["features/game-session/index.ts"],
      "@/features/game-session/*": ["features/game-session/*"],
      "@/features/character/*": ["features/character/*"],
      "@/features/campaign/*": ["features/campaign/*"],
      "@/features/npc/*": ["features/npc/*"],
      "@/features/characterBuilder/context": ["features/characterBuilder/context/index.ts"],
      "@/features/mechanics/domain": ["../packages/mechanics/src"],
      "@/features/mechanics/domain/*": ["../packages/mechanics/src/*"],
      "@/features/content/*": ["features/content/*"],
      "@/features/content/domain/types": ["features/content/shared/domain/types/index.ts"],
      "@/features/notification": ["features/notification/index.ts"],
      "@/features/notification/*": ["features/notification/*"],
      "@/features/session/*": ["features/session/*"],
      "@/features/skillProficiency/*": ["features/skillProficiency/*"],
      "@/features/user/*": ["features/user/*"],
      "@/features/utils": ["features/utils/index.ts"],
      "@/ui/hooks": ["ui/hooks/index.ts"],
      "@/ui/hooks/*": ["ui/hooks/*"],
      "@/ui/patterns": ["ui/patterns/index.ts"],
      "@/ui/patterns/*": ["ui/patterns/*"],
      "@/ui/primitives": ["ui/primitives/index.ts"],
      "@/ui/types": ["ui/types/index.ts"],
      "@/data": ["data/index.ts"],
      "@/data/*": ["data/*"],
      "@/domain/*": ["domain/*"],
      "@/domain/shared": ["domain/shared/index.ts"],
      "@/chat": ["features/chat/index.ts"],
      "@/services": ["services/index.ts"],
      "@/services/*": ["services/*"],
      "@/steps": ["features/characterBuilder/steps/index.ts"],
      "@/hooks": ["hooks/index.ts"],
      "@/hooks/*": ["hooks/*"],
      "@/shared": ["../shared/types/index.ts"],
      "@/shared/*": ["../shared/*"],
      "@/shared/money": ["../shared/money/index.ts"],
      "@/shared/money/*": ["../shared/money/*"],
      "@/shared/lib/media": ["../shared/lib/media/index.ts"],
      "@/shared/permissions": ["../shared/permissions/index.ts"],
      "@/shared/weight": ["../shared/weight/index.ts"],
      "@/shared/weight/*": ["../shared/weight/*"],
      "@/utils/*": ["utils/*"],

      "@/utils": ["utils/index.ts"],
      "@repo-assets/*": ["../assets/*"]
    }
  },
  "include": ["src", "packages/mechanics/src", "../assets/system/locations/objects/*.json"]
}
