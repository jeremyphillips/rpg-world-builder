# API + Socket.IO (must match vite.config.ts dev proxy target)
PORT=5001

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=dnd

# Auth (set a strong secret in production)
AUTH_SECRET=

# Frontend origin for CORS / redirects
CLIENT_URL=http://localhost:5173

# Optional
OPENAI_API_KEY=
IMAGE_BASE_URL=/uploads/
INVITE_TOKEN_EXPIRY_DAYS=14
NODE_ENV=development
